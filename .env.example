# Copy to .env and set values. Never commit .env.
# Database (12-factor: use DATABASE_URL or individual vars)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/timetracking
# Or: PGHOST=localhost PGPORT=5432 PGDATABASE=timetracking PGUSER=postgres PGPASSWORD=...

# Django
DJANGO_SECRET_KEY=your-secret-key-min-50-chars-for-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
